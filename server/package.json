{
  "name": "server",
  "version": "0.0.0",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "sequelize:init": "sequelize init",
    "db:setup": "node src/database/util/dbSetup.util.js",
    "db:status": "node src/database/util/checkMigrations.util.js",
    "db:migrate": "npx sequelize-cli db:migrate && node src/database/util/generateModels.util.js",
    "db:migrate:undo": "npx sequelize-cli db:migrate:undo",
    "db:seed:undo": "npx sequelize-cli db:seed:undo:all",
    "db:drop": "node src/database/settings/confirmation.settings.js \"⚠️ WARNING: This will DROP the database. Type 'yes' to continue: \" && npx sequelize-cli db:drop",
    "db:create": "npx sequelize-cli db:create",
    "db:seed": "npx sequelize-cli db:seed:all",
    "db:reset": "node src/database/settings/confirmation.settings.js \"⚠️ WARNING: This will RESET the database. Type 'yes' to continue: \" && npm run db:drop && npm run db:create && npm run db:migrate && npm run db:seed",
    "env:setup": "node src/database/settings/envSetup.settings.js",
    "generate:schema": "node src/database/util/generateSchema.util.js",
    "db:migrate:prod": "npx sequelize-cli db:migrate --migrations-path src/database/migrations/create && node src/database/util/generateModels.util.js",
    "db:migrate:prod:undo": "npx sequelize-cli db:migrate:undo --migrations-path src/database/migrations/create",
    "encrypt": "node src/util/cryptography.util.js encrypt",
    "decrypt": "node src/util/cryptography.util.js decrypt",
    "db:generate:migration": "npx sequelize-cli migration:generate --migrations-path src/database/migrations/create --name",
    "db:generate:seeder": "npx sequelize-cli seed:generate --seeders-path src/database/seeders --name"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.2.0",
    "chart.js": "^4.5.1",
    "child_process": "^1.0.2",
    "connect-mongo": "^5.1.0",
    "connect-mongodb-session": "^5.0.0",
    "convert-units": "^2.3.4",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "date-fns": "^3.6.0",
    "debug": "~2.6.9",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^4.22.1",
    "express-paginate": "^1.0.2",
    "express-session": "^1.18.2",
    "express-winston": "^4.2.0",
    "fs-extra": "^11.3.2",
    "http-errors": "~1.6.3",
    "joi": "^18.0.1",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "juice": "^10.0.1",
    "moment": "^2.30.1",
    "mongoose": "^7.8.7",
    "morgan": "^1.10.1",
    "mysql2": "^3.15.3",
    "node-linq": "^0.0.5",
    "nodemailer": "^7.0.13",
    "nodemon": "^3.1.10",
    "pdfmake": "^0.2.20",
    "sequelize": "^6.37.7",
    "sequelize-pack": "^1.0.4",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.1",
    "swagger": "^0.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.18.3",
    "yaml": "^2.8.1",
    "zod": "^4.1.12"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": ""
}
